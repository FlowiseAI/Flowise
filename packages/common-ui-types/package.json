    "scripts": {
        "build": "tsc",
        "clean": "rimraf dist",
        "nuke": "rimraf dist node_modules .turbo"
    },
    "dependencies": {
        "axios": "^1.7.2"
    },
    "devDependencies": {
        "rimraf": "^5.0.5",
        "typescript": "^5.4.5"
    }
