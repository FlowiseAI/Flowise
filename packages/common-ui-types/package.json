{
    "name": "@flowiseai/common-ui-types",
    "version": "0.0.0-dev.1",
    "description": "Shared UI types for Flowise frontend packages",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/FlowiseAI/Flowise.git",
        "directory": "packages/common-ui-types"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
